  const totalQ = Object.keys(QUESTIONS).length;
  const stepNum = state.history.length + 1;
  const pct = Math.round((state.history.length / totalQ) * 100);

  let breadcrumbs = "";
  state.history.forEach((h, i) => {
    if (i > 0) breadcrumbs += `<span class="crumb-arrow">›</span>`;
    breadcrumbs += `<span class="crumb-item">
      <span class="crumb-dot ${h.answerType === 'yes' ? 'active' : ''}"></span>
      <span style="max-width:80px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${h.shortQ}</span>
    </span>`;
  });
  if (breadcrumbs) breadcrumbs += `<span class="crumb-arrow">›</span>`;
  breadcrumbs += `<span class="crumb-item active"><span class="crumb-dot active"></span>${q.shortQ}</span>`;

  area.innerHTML = `
    <div class="progress-container">
      <div class="progress-meta">
        <span class="progress-label">İlerleme</span>
        <span class="progress-count">${stepNum} / ${totalQ}</span>
      </div>
      <div class="progress-track">
        <div class="progress-fill" style="width:${pct}%"></div>
      </div>
    </div>

    <div class="breadcrumb">${breadcrumbs}</div>

    ${state.history.length > 0 ? `
    <div class="back-area">
      <button class="back-btn" onclick="goBack()">← GERİ</button>
      <button class="restart-btn" style="margin-left:8px" onclick="restartQuiz()">↺ YENİDEN</button>
    </div>` : `
    <div class="back-area">
      <button class="back-btn" onclick="goToIntro()">← BAŞA DÖN</button>
    </div>`}

    <div class="question-area" id="question-card-area">
      <div class="question-card" id="q-card">
        <div class="q-number">${q.num}</div>

        <div class="q-icon-area">
          <div class="q-icon-box">
            ${q.iconSvg}
          </div>
        </div>

        <div class="q-text">${q.title}</div>
        <div class="q-hint">${q.hint}</div>

        <div class="q-info-box">${q.info}</div>

        <div class="choices-grid">
          <button class="choice-btn yes-btn" onclick="answer('yes', this)">
            <div class="choice-indicator">✓</div>
            <div class="choice-content">
              <div class="choice-label">Evet</div>
              <div class="choice-desc">${q.yes.answer}</div>
            </div>
            <span class="choice-arrow">›</span>
          </button>
          <button class="choice-btn no-btn" onclick="answer('no', this)">
            <div class="choice-indicator">✕</div>
            <div class="choice-content">
              <div class="choice-label">Hayır</div>
              <div class="choice-desc">${q.no.answer}</div>
            </div>
            <span class="choice-arrow">›</span>
          </button>
        </div>
      </div>
    </div>

    ${state.history.length > 0 ? renderHistoryPanel() : ''}
  `;
}

function renderHistoryPanel() {
  if (state.history.length === 0) return '';
  let items = state.history.map(h => `
    <div class="history-item">
      <span class="history-q">${h.shortQ}</span>
      <span class="history-a ${h.answerType}">${h.answerType === 'yes' ? 'EVET' : 'HAYIR'}</span>
    </div>
  `).join('');
  return `
    <div class="history-panel">
      <div class="history-title">Önceki cevaplar</div>
      <div class="history-list">${items}</div>
    </div>
  `;
}

function renderResult(area) {
  const sf = SUBFAMILIES[state.currentResult];
  if (!sf) return;

  // Rarity dots
  let dots = '';
  for (let i = 1; i <= 5; i++) {
    const filledClass = i <= sf.rarity ? `filled ${sf.rarityType}` : '';
    dots += `<div class="rarity-dot ${filledClass}"></div>`;
  }

  // Features
  let featHtml = Object.entries(sf.features).map(([k, v]) =>
    `<div class="feature-row">
      <div class="feature-key">${k}</div>
      <div class="feature-val">${v}</div>
    </div>`
  ).join('');

  // Genera
  let genHtml = sf.genera.map((g, i) =>
    `<div class="genus-chip" style="animation-delay:${i * 0.04}s">${g}</div>`
  ).join('');

  // Answer path
  let pathHtml = state.history.map((h, i) => `
    <div class="history-item">
      <span class="history-q">${h.shortQ}</span>
      <span class="history-a ${h.answerType}">${h.answerType === 'yes' ? 'EVET' : 'HAYIR'}</span>
    </div>
  `).join('');

  area.innerHTML = `
    <div class="result-screen">
      <div class="result-badge">✦ SONUÇ BULUNDU ✦</div>

      <div class="result-hero">
        <div class="result-icon">
          <div class="result-icon-ring"></div>
          <div class="result-icon-ring-outer"></div>
          <svg width="80" height="80" viewBox="0 0 80 80">
            <circle cx="40" cy="40" r="35" fill="${sf.colorDim}" stroke="${sf.color}" stroke-width="1.5"/>
            <text x="40" y="49" text-anchor="middle" font-size="28">${sf.icon}</text>
          </svg>
        </div>

        <div class="result-name">${sf.name}</div>
        <div class="result-subtitle">Altfamilya · Formicidae</div>

        <div class="result-tags">
          ${sf.tags.map(t => `<span class="tag">${t}</span>`).join('')}
          <span class="tag amber">${sf.genera.length} Cins</span>
          <span class="tag ${sf.rarity <= 1 ? 'red' : ''}">${sf.rarityText}</span>
        </div>

        <div class="result-desc">${sf.description}</div>

        <div class="rarity-bar">
          <span class="rarity-label">Yaygınlık</span>
          ${dots}
          <span class="rarity-text">${sf.rarityText}</span>
        </div>
      </div>

      <div class="features-card">
        <div class="features-title">Morfolojik Özellikler</div>
        <div class="features-list">${featHtml}</div>
      </div>

      <div class="genus-card">
        <div class="genus-title">Türkiye'deki Cinsleri (${sf.genera.length})</div>
        <div class="genus-grid">${genHtml}</div>
      </div>

      ${sf.note ? `
      <div class="note-card">
        <div class="note-card-title">⚠ Önemli Not</div>
        ${sf.note}
      </div>` : ''}

      ${state.history.length > 0 ? `
      <div class="features-card" style="animation-delay:0.45s">
        <div class="features-title">Cevap Yolunuz</div>
        <div class="history-list" style="gap:8px">${pathHtml}</div>
      </div>` : ''}

      <div class="result-actions">
        <button class="action-btn primary" onclick="restartQuiz()">↺ Yeniden Tespit</button>
        <button class="action-btn secondary" onclick="goToIntro()">📖 Rehber</button>
      </div>

      <div class="footer-note">
        Kaynak: karincaciftligim.com · Enesersoy45 · Formicidae Türkiye
      </div>
    </div>
  `;
}

// ============================================================
//  NAVIGATION FUNCTIONS
// ============================================================

function startQuiz() {
  state.screen = "question";
  state.currentQ = "q1";
  state.history = [];
  renderApp();
  scrollToTop();
}

function answer(type, btn) {
  // Visual feedback
  btn.classList.add('selected');
  if (type === 'no') btn.classList.add('no-selected');

  // Disable all buttons
  document.querySelectorAll('.choice-btn').forEach(b => b.style.pointerEvents = 'none');

  const q = QUESTIONS[state.currentQ];
  const branch = type === 'yes' ? q.yes : q.no;

  // Record history
  state.history.push({
    qId: state.currentQ,
    shortQ: q.shortQ,
    answer: branch.answer,
    answerType: type,
  });

  // Short delay for visual feedback
  setTimeout(() => {
    const card = document.getElementById('q-card');
    if (card) card.classList.add('fade-out');

    setTimeout(() => {
      const next = branch.next;
      if (next.startsWith('result_')) {
        const sfKey = next.replace('result_', '');
        state.screen = "result";
        state.currentResult = sfKey;
        renderApp();
      } else {
        state.currentQ = next;
        renderApp();
      }
      scrollToTop();
    }, 280);
  }, 220);
}

function goBack() {
  if (state.history.length === 0) {
    goToIntro();
    return;
  }
  state.history.pop();
  if (state.history.length === 0) {
    state.currentQ = "q1";
  } else {
    // Replay to find current question
    replayHistory();
  }
  state.screen = "question";
  renderApp();
  scrollToTop();
}

function replayHistory() {
  let cur = "q1";
  state.history.forEach((h, i) => {
    if (i < state.history.length) {
      const q = QUESTIONS[cur];
      if (!q) return;
      const branch = h.answerType === 'yes' ? q.yes : q.no;
      cur = branch.next;
    }
  });
  state.currentQ = cur.startsWith('result_') ? cur : cur;
  if (cur.startsWith('result_')) {
    state.currentQ = null;
  }
}

function restartQuiz() {
  state.screen = "question";
  state.currentQ = "q1";
  state.history = [];
  state.currentResult = null;
  renderApp();
  scrollToTop();
}

function goToIntro() {
  state.screen = "intro";
  state.currentQ = null;
  state.history = [];
  state.currentResult = null;
  renderApp();
  scrollToTop();
}

function scrollToTop() {
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

// ============================================================
//  INIT
// ============================================================
renderApp();

// Keyboard support
document.addEventListener('keydown', (e) => {
  if (state.screen !== 'question') return;
  if (e.key === 'ArrowRight' || e.key === 'y' || e.key === 'Y' || e.key === '1') {
    const yesBtn = document.querySelector('.yes-btn');
    if (yesBtn && !yesBtn.style.pointerEvents) answer('yes', yesBtn);
  }
  if (e.key === 'ArrowLeft' || e.key === 'n' || e.key === 'N' || e.key === '2') {
    const noBtn = document.querySelector('.no-btn');
    if (noBtn && !noBtn.style.pointerEvents) answer('no', noBtn);
  }
  if (e.key === 'Backspace' || e.key === 'ArrowUp') {
    if (state.history.length > 0) goBack();
  }
});

// Touch swipe hints removed for cleanliness
// Prevent double-tap zoom on buttons
document.addEventListener('touchend', (e) => {
  if (e.target.matches('button') || e.target.closest('button')) {
    e.preventDefault();
  }
}, { passive: false });
</script>
