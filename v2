<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Karınca Altfamilya Tespiti</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Space+Mono:wght@400;700&family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,300;1,400&display=swap" rel="stylesheet">

<style>
  :root {
    --bg-deepest: #080b07;
    --bg-deep: #0d1209;
    --bg-card: #111a0d;
    --bg-card2: #162010;
    --border: #2a3d1c;
    --border-glow: #4a7a28;
    --amber: #d4821a;
    --amber-light: #f0a830;
    --amber-pale: #f5c860;
    --green-dim: #2d5016;
    --green-mid: #3d6b1e;
    --green-bright: #5a9e2a;
    --green-glow: #7ac43a;
    --text-primary: #e8ddc8;
    --text-secondary: #a89878;
    --text-muted: #5c6648;
    --text-accent: #d4821a;
    --red-dim: #6b1515;
    --red-bright: #c43a3a;
    --shadow-green: 0 0 20px rgba(90,158,42,0.15);
    --shadow-amber: 0 0 20px rgba(212,130,26,0.2);
    --radius: 12px;
    --radius-sm: 8px;
    --transition: 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    -webkit-tap-highlight-color: transparent;
  }

  html {
    height: 100%;
    scroll-behavior: smooth;
  }

  body {
    background: var(--bg-deepest);
    color: var(--text-primary);
    font-family: 'Crimson Pro', serif;
    min-height: 100vh;
    overflow-x: hidden;
    position: relative;
    font-size: 16px;
    line-height: 1.6;
  }

  /* === BACKGROUND EFFECTS === */
  .bg-noise {
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
    opacity: 0.6;
  }

  .bg-radial {
    position: fixed;
    top: -30%;
    left: 50%;
    transform: translateX(-50%);
    width: 130%;
    height: 70vh;
    background: radial-gradient(ellipse at center, rgba(58,108,20,0.12) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .bg-radial-bottom {
    position: fixed;
    bottom: -20%;
    right: -10%;
    width: 60%;
    height: 50vh;
    background: radial-gradient(ellipse at center, rgba(180,100,10,0.06) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  /* === GRID LINES === */
  .bg-grid {
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(58,108,20,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(58,108,20,0.04) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  /* === MAIN WRAPPER === */
  #app {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 0 60px 0;
    max-width: 620px;
    margin: 0 auto;
  }

  /* === HEADER === */
  .app-header {
    width: 100%;
    padding: 28px 20px 20px;
    text-align: center;
    position: relative;
  }

  .header-eyebrow {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    letter-spacing: 4px;
    color: var(--green-bright);
    text-transform: uppercase;
    margin-bottom: 10px;
    opacity: 0.8;
  }

  .header-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(22px, 6vw, 32px);
    font-weight: 900;
    color: var(--text-primary);
    line-height: 1.15;
    letter-spacing: -0.5px;
  }

  .header-title span {
    color: var(--amber);
    font-style: italic;
  }

  .header-subtitle {
    font-family: 'Crimson Pro', serif;
    font-size: 14px;
    color: var(--text-secondary);
    margin-top: 8px;
    font-style: italic;
  }

  .header-divider {
    margin: 18px auto 0;
    width: 60px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--amber), transparent);
  }

  /* === ANT SVG LOGO === */
  .ant-logo-wrapper {
    margin: 0 auto 6px;
    width: 56px;
    height: 56px;
    position: relative;
  }

  .ant-logo-glow {
    position: absolute;
    inset: -8px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(212,130,26,0.2) 0%, transparent 70%);
    animation: pulse-glow 3s ease-in-out infinite;
  }

  @keyframes pulse-glow {
    0%, 100% { opacity: 0.6; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.1); }
  }

  /* === PROGRESS BAR === */
  .progress-container {
    width: 100%;
    padding: 0 20px;
    margin-bottom: 8px;
  }

  .progress-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
  }

  .progress-label {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .progress-count {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    color: var(--amber);
  }

  .progress-track {
    width: 100%;
    height: 3px;
    background: var(--border);
    border-radius: 2px;
    overflow: visible;
    position: relative;
  }

  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--green-mid), var(--amber));
    border-radius: 2px;
    transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
  }

  .progress-fill::after {
    content: '';
    position: absolute;
    right: -3px;
    top: 50%;
    transform: translateY(-50%);
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--amber-light);
    box-shadow: 0 0 8px var(--amber);
  }

  /* === BREADCRUMB === */
  .breadcrumb {
    width: 100%;
    padding: 6px 20px;
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    align-items: center;
    min-height: 32px;
  }

  .crumb-item {
    display: flex;
    align-items: center;
    gap: 4px;
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    color: var(--text-muted);
    letter-spacing: 0.5px;
  }

  .crumb-item.active {
    color: var(--green-bright);
  }

  .crumb-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--text-muted);
    flex-shrink: 0;
  }

  .crumb-dot.active {
    background: var(--amber);
    box-shadow: 0 0 6px var(--amber);
  }

  .crumb-arrow {
    color: var(--border);
    font-size: 10px;
    margin-left: 2px;
  }

  /* === QUESTION CARD === */
  .question-area {
    width: 100%;
    padding: 0 16px;
    perspective: 1000px;
  }

  .question-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px 20px 20px;
    position: relative;
    overflow: hidden;
    animation: slideInCard 0.45s cubic-bezier(0.4, 0, 0.2, 1) both;
  }

  @keyframes slideInCard {
    from {
      opacity: 0;
      transform: translateY(16px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .question-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--green-bright), var(--amber), transparent);
    opacity: 0.6;
  }

  .question-card::after {
    content: '';
    position: absolute;
    top: -40%;
    right: -20%;
    width: 60%;
    height: 180%;
    background: radial-gradient(ellipse, rgba(58,108,20,0.06) 0%, transparent 60%);
    pointer-events: none;
  }

  .q-number {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    letter-spacing: 3px;
    color: var(--amber);
    text-transform: uppercase;
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .q-number::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, var(--border), transparent);
  }

  .q-icon-area {
    display: flex;
    justify-content: center;
    margin: 12px 0 20px;
  }

  .q-icon-box {
    width: 88px;
    height: 88px;
    border: 1px solid var(--border);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: radial-gradient(circle at 30% 30%, rgba(90,158,42,0.1), transparent 70%);
    position: relative;
    animation: rotateGlow 8s linear infinite;
  }

  @keyframes rotateGlow {
    from { box-shadow: 0 0 15px rgba(90,158,42,0.1), inset 0 0 15px rgba(90,158,42,0.05); }
    50% { box-shadow: 0 0 25px rgba(212,130,26,0.15), inset 0 0 20px rgba(212,130,26,0.07); }
    to { box-shadow: 0 0 15px rgba(90,158,42,0.1), inset 0 0 15px rgba(90,158,42,0.05); }
  }

  .q-text {
    font-family: 'Playfair Display', serif;
    font-size: clamp(17px, 4.5vw, 21px);
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.4;
    margin-bottom: 6px;
    text-align: center;
  }

  .q-hint {
    font-size: 13px;
    color: var(--text-secondary);
    font-style: italic;
    text-align: center;
    line-height: 1.5;
    margin-bottom: 22px;
    padding: 0 4px;
  }

  /* === INFO BOX === */
  .q-info-box {
    background: rgba(58,108,20,0.08);
    border: 1px solid rgba(58,108,20,0.2);
    border-radius: var(--radius-sm);
    padding: 12px 14px;
    margin-bottom: 20px;
    font-size: 12.5px;
    color: var(--text-secondary);
    line-height: 1.6;
    position: relative;
    font-style: italic;
  }

  .q-info-box::before {
    content: '🔬';
    display: block;
    font-style: normal;
    font-size: 14px;
    margin-bottom: 4px;
  }

  /* === ANATOMY SVG ILLUSTRATIONS === */
  .anatomy-svg {
    display: block;
    margin: 0 auto;
    filter: drop-shadow(0 2px 8px rgba(0,0,0,0.4));
  }

  /* === CHOICE BUTTONS === */
  .choices-grid {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .choice-btn {
    width: 100%;
    background: var(--bg-card2);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 14px 18px;
    cursor: pointer;
    text-align: left;
    transition: var(--transition);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    gap: 14px;
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
    animation: fadeInBtn 0.4s ease both;
  }

  .choice-btn:nth-child(1) { animation-delay: 0.1s; }
  .choice-btn:nth-child(2) { animation-delay: 0.18s; }
  .choice-btn:nth-child(3) { animation-delay: 0.26s; }

  @keyframes fadeInBtn {
    from { opacity: 0; transform: translateX(-12px); }
    to { opacity: 1; transform: translateX(0); }
  }

  .choice-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(90,158,42,0.08) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .choice-btn:hover::before,
  .choice-btn:active::before {
    opacity: 1;
  }

  .choice-btn:hover,
  .choice-btn:active {
    border-color: var(--green-bright);
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(90,158,42,0.12);
  }

  .choice-btn.yes-btn:hover,
  .choice-btn.yes-btn:active {
    border-color: var(--green-bright);
    box-shadow: 0 4px 20px rgba(90,158,42,0.2);
  }

  .choice-btn.no-btn:hover,
  .choice-btn.no-btn:active {
    border-color: var(--amber);
    box-shadow: 0 4px 20px rgba(212,130,26,0.15);
  }

  .choice-indicator {
    width: 34px;
    height: 34px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 16px;
    transition: var(--transition);
  }

  .yes-btn .choice-indicator {
    background: rgba(90,158,42,0.15);
    border: 1px solid rgba(90,158,42,0.3);
    color: var(--green-bright);
  }

  .no-btn .choice-indicator {
    background: rgba(212,130,26,0.12);
    border: 1px solid rgba(212,130,26,0.25);
    color: var(--amber);
  }

  .choice-content {
    flex: 1;
  }

  .choice-label {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 3px;
    transition: color 0.3s;
  }

  .yes-btn .choice-label { color: var(--green-bright); }
  .no-btn .choice-label { color: var(--amber); }

  .choice-desc {
    font-size: 13.5px;
    color: var(--text-secondary);
    line-height: 1.45;
  }

  .choice-arrow {
    color: var(--text-muted);
    font-size: 14px;
    transition: transform 0.3s, color 0.3s;
  }

  .choice-btn:hover .choice-arrow {
    transform: translateX(4px);
    color: var(--green-bright);
  }

  /* === BACK BUTTON === */
  .back-area {
    width: 100%;
    padding: 12px 16px 4px;
    display: flex;
    justify-content: flex-start;
  }

  .back-btn {
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 7px 16px;
    color: var(--text-muted);
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 1px;
    cursor: pointer;
    transition: var(--transition);
    display: flex;
    align-items: center;
    gap: 6px;
    touch-action: manipulation;
  }

  .back-btn:hover {
    border-color: var(--border-glow);
    color: var(--text-secondary);
    background: rgba(58,108,20,0.07);
  }

  .back-btn:disabled {
    opacity: 0.3;
    pointer-events: none;
  }

  /* === RESTART BTN === */
  .restart-btn {
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 7px 16px;
    color: var(--text-muted);
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    letter-spacing: 1px;
    cursor: pointer;
    transition: var(--transition);
    display: flex;
    align-items: center;
    gap: 6px;
    touch-action: manipulation;
  }

  .restart-btn:hover {
    border-color: var(--amber);
    color: var(--amber);
    background: rgba(212,130,26,0.07);
  }

  /* === RESULT SCREEN === */
  .result-screen {
    width: 100%;
    padding: 0 16px;
    animation: resultReveal 0.6s cubic-bezier(0.4, 0, 0.2, 1) both;
  }

  @keyframes resultReveal {
    from {
      opacity: 0;
      transform: translateY(24px) scale(0.96);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .result-badge {
    text-align: center;
    margin-bottom: 4px;
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    letter-spacing: 4px;
    color: var(--green-bright);
    text-transform: uppercase;
    animation: fadeInUp 0.5s 0.1s both;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .result-hero {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 28px 20px 24px;
    margin-bottom: 14px;
    position: relative;
    overflow: hidden;
    text-align: center;
    animation: fadeInUp 0.5s 0.15s both;
  }

  .result-hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--green-dim), var(--green-bright), var(--amber-light), var(--green-bright), var(--green-dim));
    background-size: 200% 100%;
    animation: shimmerBorder 3s linear infinite;
  }

  @keyframes shimmerBorder {
    from { background-position: 200% 0; }
    to { background-position: -200% 0; }
  }

  .result-hero::after {
    content: '';
    position: absolute;
    bottom: -30%;
    left: 50%;
    transform: translateX(-50%);
    width: 80%;
    height: 60%;
    background: radial-gradient(ellipse, rgba(90,158,42,0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .result-icon {
    width: 80px;
    height: 80px;
    margin: 0 auto 18px;
    position: relative;
  }

  .result-icon-ring {
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    border: 1px solid var(--green-bright);
    opacity: 0.4;
    animation: ringPulse 2.5s ease-in-out infinite;
  }

  .result-icon-ring-outer {
    position: absolute;
    inset: -14px;
    border-radius: 50%;
    border: 1px solid var(--amber);
    opacity: 0.2;
    animation: ringPulse 2.5s ease-in-out infinite 0.5s;
  }

  @keyframes ringPulse {
    0%, 100% { transform: scale(1); opacity: 0.2; }
    50% { transform: scale(1.05); opacity: 0.5; }
  }

  .result-name {
    font-family: 'Playfair Display', serif;
    font-size: clamp(26px, 7vw, 34px);
    font-weight: 900;
    font-style: italic;
    color: var(--amber-light);
    margin-bottom: 4px;
    letter-spacing: -0.5px;
    text-shadow: 0 0 30px rgba(212,130,26,0.3);
  }

  .result-subtitle {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    letter-spacing: 3px;
    color: var(--text-muted);
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .result-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 16px;
  }

  .tag {
    background: rgba(58,108,20,0.15);
    border: 1px solid rgba(58,108,20,0.3);
    border-radius: 20px;
    padding: 4px 12px;
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    letter-spacing: 1px;
    color: var(--green-bright);
    text-transform: uppercase;
  }

  .tag.amber {
    background: rgba(212,130,26,0.12);
    border-color: rgba(212,130,26,0.25);
    color: var(--amber-light);
  }

  .tag.red {
    background: rgba(180,40,40,0.12);
    border-color: rgba(180,40,40,0.25);
    color: #e07070;
  }

  .result-desc {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.65;
    font-style: italic;
    border-top: 1px solid var(--border);
    padding-top: 14px;
  }

  /* === FEATURES GRID === */
  .features-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 18px 18px;
    margin-bottom: 14px;
    animation: fadeInUp 0.5s 0.25s both;
  }

  .features-title {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    letter-spacing: 3px;
    color: var(--text-muted);
    text-transform: uppercase;
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .features-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .features-list {
    display: grid;
    gap: 10px;
  }

  .feature-row {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .feature-key {
    font-family: 'Space Mono', monospace;
    font-size: 10px;
    color: var(--amber);
    min-width: 88px;
    flex-shrink: 0;
    padding-top: 2px;
    letter-spacing: 0.5px;
  }

  .feature-val {
    font-size: 13.5px;
    color: var(--text-primary);
    line-height: 1.45;
  }

  .feature-val .yes { color: var(--green-bright); font-weight: 600; }
  .feature-val .no { color: #e07070; }
  .feature-val .maybe { color: var(--amber-light); }
  .feature-val .special { color: var(--amber-pale); font-style: italic; }

  /* === GENUS LIST === */
  .genus-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 18px 18px;
    margin-bottom: 14px;
    animation: fadeInUp 0.5s 0.35s both;
  }

  .genus-title {
    font-family: 'Space Mono', monospace;
    font-size: 9px;
    letter-spacing: 3px;
    color: var(--text-muted);
    text-transform: uppercase;
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .genus-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .genus-grid {
